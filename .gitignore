# ============================================================
# BTV Chat Corp — .gitignore
# ============================================================

# Segredos — NUNCA commitar
.env
.env.local
.env.*.local
.env.production
.env.staging
*.pem
*.key
*.crt
*.p12
nginx/ssl/**
!nginx/ssl/.gitkeep

# Rust
target/
Cargo.lock
**/*.rs.bk

# Node / Angular
node_modules/
dist/
.angular/
*.js.map

# Python (stubs removidos, mas por garantia)
__pycache__/
*.pyc
*.pyo
*.pyd
.pytest_cache/
venv/
.venv/

# Docker
docker-compose.override.yml

# IDEs
.vscode/
.idea/
*.swp
*.swo

# OS
.DS_Store
Thumbs.db

# Logs
*.log
logs/

# Uploads locais
uploads/
