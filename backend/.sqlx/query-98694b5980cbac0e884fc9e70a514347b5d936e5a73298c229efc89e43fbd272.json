  "query": "\n        SELECT id, webhook_id, event_type, status, attempt_number,\n               http_status, response_time_ms, error_message,\n               scheduled_at, delivered_at, next_retry_at\n        FROM webhook_deliveries\n        WHERE webhook_id = $1\n        ORDER BY scheduled_at DESC\n        LIMIT 100\n        ",
