# /etc/cron.d/ai-training
# Cron jobs para automacao do ciclo de treinamento de IA
# Instalar com: sudo cp ai-training /etc/cron.d/ && sudo chmod 644 /etc/cron.d/ai-training

SHELL=/bin/bash
PATH=/usr/local/sbin:/usr/local/bin:/sbin:/bin:/usr/sbin:/usr/bin

# Variaveis de ambiente (ajustar conforme ambiente)
DATABASE_URL=postgresql://user:pass@localhost:5432/btvchat
VLLM_URL=http://localhost:8000
BASE_MODEL=meta-llama/Llama-3.3-70B
LORA_DIR=/models/lora
MIN_TRAINING_EXAMPLES=50
QUESTIONS_PER_CHUNK=3

# Treina todo domingo as 3h da manha (baixo uso)
0 3 * * 0 root cd /app/training && python3 run_cycle.py --all-workspaces >> /var/log/ai-training.log 2>&1

# Gera Q&A sinteticos de novos documentos toda quarta as 2h
0 2 * * 3 root cd /app/training && python3 generate_synthetic_qa.py >> /var/log/ai-qa-gen.log 2>&1

# Limpa dados rejeitados todo dia 1 do mes as 4h
0 4 1 * * root cd /app/training && python3 cleanup_rejected.py >> /var/log/ai-cleanup.log 2>&1

# Health check do servico vLLM a cada 5 minutos
*/5 * * * * root curl -sf http://localhost:8000/health || echo "[$(date)] vLLM DOWN" >> /var/log/ai-health.log
