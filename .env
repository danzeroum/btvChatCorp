# ============================================================
# BTV Chat Corp — Variáveis de ambiente
# ============================================================
# ATENCAO: Este arquivo NAO deve conter credenciais reais.
# Copie .env.example, preencha os valores e NUNCA commite .env.
# ============================================================

# PostgreSQL
POSTGRES_USER=TROQUE_AQUI
POSTGRES_PASSWORD=TROQUE_AQUI
POSTGRES_DB=btvchat

# Qdrant
QDRANT_API_KEY=TROQUE_AQUI

# JWT (gere com: openssl rand -hex 32)
JWT_SECRET=TROQUE_AQUI_MIN_64_CHARS

# ============================================================
# LLM — Ollama (self-hosted ou BTV-managed cloud)
# ============================================================
OLLAMA_HOST=TROQUE_AQUI
OLLAMA_AUTH_USER=TROQUE_AQUI
OLLAMA_AUTH_PASS=TROQUE_AQUI
OLLAMA_MODEL=mistral:latest

# CORS (separe multiplas origens por vírgula)
ALLOWED_ORIGINS=http://localhost:4200

# Logs
RUST_LOG=info
