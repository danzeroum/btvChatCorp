# ============================================================
# BTV Chat Corp — Template de Variáveis de Ambiente
# ============================================================
# Como usar:
#   cp .env.example .env
#   Edite .env preenchendo TODOS os campos marcados como TROQUE_AQUI
#   NUNCA commite o arquivo .env — ele está no .gitignore
# ============================================================

# ---- PostgreSQL ----
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=TROQUE_AQUI
POSTGRES_PASSWORD=TROQUE_AQUI          # gere com: openssl rand -base64 24
POSTGRES_DB=btvchat
# URL completa de conexão — OBRIGATORIA para a API (Rust) e para o serviço de
# treinamento (backend/training/config.py recusa iniciar sem ela).
DATABASE_URL=postgresql://TROQUE_AQUI:TROQUE_AQUI@localhost:5432/btvchat

# ---- Qdrant (Vector DB) ----
QDRANT_HOST=localhost
QDRANT_PORT=6333
QDRANT_API_KEY=TROQUE_AQUI             # gere com: openssl rand -hex 32

# ---- JWT ----
# OBRIGATORIO: gere com: openssl rand -hex 32
# O sistema recusa inicializar sem este valor configurado
JWT_SECRET=TROQUE_AQUI_MIN_64_CHARS
# Validade do access token em horas (default 1). Token expirado é renovado via
# POST /api/v1/auth/refresh enquanto ainda válido.
JWT_EXPIRY_HOURS=1

# ---- API Keys ----
# OBRIGATORIO: segredo para HMAC-SHA256 do hash das API keys (gere com: openssl rand -hex 32)
# A API recusa inicializar sem este valor.
API_KEY_HMAC_SECRET=TROQUE_AQUI_HEX_32

# ---- Serviços internos (Python: embedding / reranker / document-processor) ----
# Token compartilhado exigido no header X-Internal-Token das chamadas internas.
# gere com: openssl rand -hex 32
INTERNAL_SERVICE_TOKEN=TROQUE_AQUI_HEX_32
# Revisão (hash de commit do HuggingFace) fixa para modelos carregados com
# trust_remote_code — trava o código remoto executado a uma versão auditada.
EMBEDDING_MODEL_REVISION=TROQUE_AQUI_COMMIT_HASH
# URL do servidor vLLM usado pelo serviço de treinamento
VLLM_URL=http://localhost:8000

# ---- Ollama / LLM ----
# Modo self-hosted: OLLAMA_HOST=http://localhost:11434
# Modo BTV-managed: solicite credenciais ao time BTV
OLLAMA_HOST=TROQUE_AQUI
OLLAMA_AUTH_USER=TROQUE_AQUI
OLLAMA_AUTH_PASS=TROQUE_AQUI
OLLAMA_MODEL=mistral:latest
# Modelos disponíveis: mistral:latest | llama3.1:8b | llama3.3:70b | gemma3:12b

# ---- SMTP (email de notificações) ----
SMTP_HOST=TROQUE_AQUI
SMTP_PORT=587
SMTP_USER=TROQUE_AQUI
SMTP_PASSWORD=TROQUE_AQUI              # use App Password, nunca senha principal

# ---- CORS ----
# Separe mútiplas origens por vírgula
# Producão: https://app.seudominio.com,https://admin.seudominio.com
ALLOWED_ORIGINS=http://localhost:4200

# ---- Redis (Sprint 1 — refresh tokens) ----
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=TROQUE_AQUI

# ---- Logs ----
RUST_LOG=info
