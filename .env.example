# ============================================================
# BTV Chat Corp — Variáveis de ambiente de produção
# Copie para .env e preencha TODOS os valores antes de subir
# ============================================================

# PostgreSQL
POSTGRES_USER=btv
POSTGRES_PASSWORD=TROQUE_POR_SENHA_FORTE
POSTGRES_DB=btvchat

# Redis
REDIS_PASSWORD=TROQUE_POR_SENHA_FORTE

# Qdrant
QDRANT_API_KEY=TROQUE_POR_CHAVE_FORTE

# JWT (gere com: openssl rand -hex 64)
JWT_SECRET=GERE_COM_OPENSSL
JWT_REFRESH_SECRET=GERE_COM_OPENSSL

# Criptografia AES (gere com: openssl rand -hex 32)
ENCRYPTION_KEY=GERE_COM_OPENSSL

# Hugging Face (para baixar Llama 3.3 70B)
HF_TOKEN=hf_XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX

# GPU
GPU_COUNT=2
EMBEDDING_GPU=1

# SMTP (para convites e notificações)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=seu@email.com
SMTP_PASSWORD=sua_senha_app

# URLs
API_URL=/api
ALLOWED_ORIGINS=https://chat.seudominio.com

# Logs
LOG_LEVEL=info
RUST_LOG=info

# Document Processor
DOC_PROCESSOR_WORKERS=4
