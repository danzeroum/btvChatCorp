# ============================================================
# BTV Chat Corp — variaveis de ambiente
# Copie para .env e preencha os valores reais.
# NUNCA commite o .env no repositorio.
# ============================================================

# --- Banco de dados (obrigatorio) ---
DATABASE_URL=postgres://user:password@localhost:5432/btvchat
# Numero maximo de conexoes no pool (default: 10)
DB_MAX_CONN=10

# --- Seguranca (obrigatorio) ---
# Gere com: openssl rand -hex 64
JWT_SECRET=<gere-com-openssl-rand-hex-64>

# --- LLM / Ollama (opcional, tem defaults) ---
OLLAMA_URL=https://api.buildtovalue.cloud
OLLAMA_MODEL=mistral:latest
# Deixe em branco se o Ollama nao exigir autenticacao
OLLAMA_AUTH_USER=
OLLAMA_AUTH_PASS=

# --- Servicos externos (opcional, tem defaults) ---
QDRANT_URL=http://localhost:6333
QDRANT_API_KEY=
EMBEDDING_URL=http://localhost:8001

# --- Servidor (opcional) ---
BIND_ADDR=0.0.0.0:3000

# --- Frontend (opcional) ---
FRONTEND_URL=http://localhost:4200
