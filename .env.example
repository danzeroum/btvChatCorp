# BTV Chat Corp — variaveis de ambiente
# Copie para .env e preencha com valores reais.
# NUNCA commite o arquivo .env.

# PostgreSQL
POSTGRES_USER=btv
POSTGRES_PASSWORD=TROQUE_AQUI
POSTGRES_DB=btvchat

# Redis
REDIS_PASSWORD=TROQUE_AQUI

# JWT (gere com: openssl rand -hex 32)
JWT_SECRET=TROQUE_AQUI

# Qdrant
QDRANT_API_KEY=TROQUE_AQUI

# LLM
OLLAMA_HOST=http://ollama:11434
OLLAMA_MODEL=llama3:8b
OLLAMA_AUTH_USER=
OLLAMA_AUTH_PASS=

# BTV Gateway
GATEWAY_RATE_LIMIT_RPM=60

# CORS (separados por virgula)
ALLOWED_ORIGINS=http://localhost:4200,https://app.btvc.com

# Logging
RUST_LOG=info
