# ============================================================
# BTV Chat Corp — Template de Variáveis de Ambiente
# ============================================================
# Como usar:
#   cp .env.example .env
#   Edite .env preenchendo TODOS os campos marcados como TROQUE_AQUI
#   NUNCA commite o arquivo .env — ele está no .gitignore
# ============================================================

# ---- PostgreSQL ----
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=TROQUE_AQUI
POSTGRES_PASSWORD=TROQUE_AQUI          # gere com: openssl rand -base64 24
POSTGRES_DB=btvchat

# ---- Qdrant (Vector DB) ----
QDRANT_HOST=localhost
QDRANT_PORT=6333
QDRANT_API_KEY=TROQUE_AQUI             # gere com: openssl rand -hex 32

# ---- JWT ----
# OBRIGATORIO: gere com: openssl rand -hex 32
# O sistema recusa inicializar sem este valor configurado
JWT_SECRET=TROQUE_AQUI_MIN_64_CHARS

# ---- Ollama / LLM ----
# Modo self-hosted: OLLAMA_HOST=http://localhost:11434
# Modo BTV-managed: solicite credenciais ao time BTV
OLLAMA_HOST=TROQUE_AQUI
OLLAMA_AUTH_USER=TROQUE_AQUI
OLLAMA_AUTH_PASS=TROQUE_AQUI
OLLAMA_MODEL=mistral:latest
# Modelos disponíveis: mistral:latest | llama3.1:8b | llama3.3:70b | gemma3:12b

# ---- SMTP (email de notificações) ----
SMTP_HOST=TROQUE_AQUI
SMTP_PORT=587
SMTP_USER=TROQUE_AQUI
SMTP_PASSWORD=TROQUE_AQUI              # use App Password, nunca senha principal

# ---- CORS ----
# Separe mútiplas origens por vírgula
# Producão: https://app.seudominio.com,https://admin.seudominio.com
ALLOWED_ORIGINS=http://localhost:4200

# ---- Redis (Sprint 1 — refresh tokens) ----
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=TROQUE_AQUI

# ---- Logs ----
RUST_LOG=info
