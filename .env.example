# ============================================================
# BTV Chat Corp — Variáveis de ambiente
# Copie para .env e preencha TODOS os valores antes de subir
# ============================================================

# PostgreSQL
POSTGRES_USER=btv
POSTGRES_PASSWORD=TROQUE_POR_SENHA_FORTE
POSTGRES_DB=btvchat

# Redis
REDIS_PASSWORD=TROQUE_POR_SENHA_FORTE

# Qdrant
QDRANT_API_KEY=TROQUE_POR_CHAVE_FORTE

# JWT (gere com: openssl rand -hex 64)
JWT_SECRET=GERE_COM_OPENSSL
JWT_REFRESH_SECRET=GERE_COM_OPENSSL

# Criptografia AES (gere com: openssl rand -hex 32)
ENCRYPTION_KEY=GERE_COM_OPENSSL

# ============================================================
# PROVEDOR LLM — escolha um dos dois modos abaixo
# ============================================================
# Modo "vllm"  — roda o modelo localmente (requer GPU H100)
# Modo "ollama" — usa um servidor Ollama externo (VPS, dev)
LLM_PROVIDER=ollama

# --- Modo vllm (produção local) ---
VLLM_URL=http://vllm:8000
VLLM_MODEL=llama3
HF_TOKEN=hf_XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX
GPU_COUNT=2
EMBEDDING_GPU=1

# --- Modo ollama (VPS / desenvolvimento) ---
OLLAMA_HOST=https://api.buildtovalue.cloud
OLLAMA_AUTH_USER=buildtovalue
OLLAMA_AUTH_PASS=BTV_secure_2026!
# Modelo que será usado — deve existir no servidor Ollama
# Exemplos: llama3.3:70b  |  llama3.1:8b  |  mistral:7b  |  gemma3:12b
OLLAMA_MODEL=llama3.3:70b

# SMTP
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=seu@email.com
SMTP_PASSWORD=sua_senha_app

# URLs
API_URL=/api
ALLOWED_ORIGINS=https://chat.seudominio.com

# Logs
LOG_LEVEL=info
RUST_LOG=info

# Document Processor
DOC_PROCESSOR_WORKERS=4
